# Ignore system files
.DS_Store
Thumbs.db

# Ignore editor files
.vscode/
.idea/

# Ignore logs
*.log

# Ignore temp files
*.tmp
*.temp

# Ignore large model files
models/*.bin
models/*.glb
models/*.gltf

# Keep the models folder but ignore large files
!models/.gitkeep

# Character sheets are user-specific and should not be committed
models/character.json
character.json

# Ignore downloaded libraries
libs/*

# Keep the libs folder but ignore all files
!libs/.gitkeep

# Ignore voice samples (can be large)
voice/*.wav
voice/*.mp3
voice/*.bin
voice/*.onnx

# Keep the voice folder but ignore large files
!voice/.gitkeep

# Ignore any model cache files
*.pt
*.pth
*.ckpt
__pycache__/
*.pyc

# --- Claude Code internal files ---
# Do not commit planning/notes files
TASKS.md
prd.md
# Exclude entire .claude folder (agent memory, logs)
.claude/
