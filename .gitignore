# Ignore system files
.DS_Store
Thumbs.db

# Ignore editor files
.vscode/
.idea/

# Ignore logs
*.log

# Ignore temp files
*.tmp
*.temp

# Ignore large model files
models/*.bin
models/*.glb
models/*.gltf

# Keep the models folder but ignore large files
!models/.gitkeep

# Ignore downloaded libraries
libs/

# Keep the libs folder but ignore all files
!libs/.gitkeep

# Ignore voice samples (can be large)
voice/*.wav
voice/*.mp3
voice/*.bin
voice/*.onnx

# Keep the voice folder but ignore large files
!voice/.gitkeep

# Ignore any model cache files
*.pt
*.pth
*.ckpt
__pycache__/
*.pyc
